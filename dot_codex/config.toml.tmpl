hide_agent_reasoning = true
network_access = true
approval_policy = "never"
sandbox_mode = "danger-full-access"
model = "gpt-5.5"
model_reasoning_effort = "medium"

[features]
external_migration = false
suppress_unstable_features_warning = true
goals = true

[tools]
unified_exec = true
streamable_shell = true

[tui]
status_line = [
  "model-with-reasoning",
  "fast-mode",
  "git-branch",
  "context-remaining",
  "five-hour-limit",
  "weekly-limit",
  "used-tokens",
  "current-dir",
]

# Suppress model-availability NUX banners by pinning shown_count to the
# MAX_SHOW_COUNT (4) defined in codex-rs/tui/src/app/startup_prompts.rs.
[tui.model_availability_nux]
"gpt-5.5" = 4

{{- if lookPath "ghq" }}
{{- range $repo := (splitList "\n" (trim (output "ghq" "list" "-p"))) }}
{{- if $repo }}
[projects.{{ $repo | quote }}]
trust_level = "trusted"

{{- end }}
{{- end }}
{{- end }}
