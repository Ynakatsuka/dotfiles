#!/usr/bin/env bash
# chezmoi modify_ script: merge "command(*)" into permissions.allow so the
# Antigravity CLI (agy) auto-approves every shell command. The CLI itself
# rewrites this file at runtime (e.g. trustedWorkspaces), so we read the
# current contents from stdin and only adjust the fields we own.
set -euo pipefail

if ! command -v jq >/dev/null 2>&1; then
  cat
  exit 0
fi

input=$(cat)
[[ -z "$input" ]] && input='{}'

printf '%s' "$input" | jq '
  .permissions.allow = (
    ((.permissions.allow // []) + ["command(*)"]) | unique
  )
'
