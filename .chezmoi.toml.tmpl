{{- $ageCmd := "" -}}
{{- range $candidate := list "/usr/bin/age" "/usr/local/bin/age" "/opt/homebrew/bin/age" (joinPath .chezmoi.homeDir ".local/bin/age") (joinPath .chezmoi.homeDir ".local/share/mise/installs/age/1.3.1/bin/age") -}}
{{-   if and (not $ageCmd) (stat $candidate) -}}
{{-     $ageCmd = $candidate -}}
{{-   end -}}
{{- end -}}
{{- $pathAge := lookPath "age" -}}
{{- if and (not $ageCmd) $pathAge (not (contains "mise/shims/age" $pathAge)) -}}
{{-   $ageCmd = $pathAge -}}
{{- end -}}
{{- if and $ageCmd (stat (joinPath .chezmoi.homeDir ".config/chezmoi/key.txt")) -}}
encryption = "age"

[age]
    identity = "~/.config/chezmoi/key.txt"
    recipient = "age1w5ek6kq90p7cgs3k4s47ug2lz8p82l5lnac8pckapv45zxyygvnq9ec0pe"
    command = {{ $ageCmd | quote }}
{{- end }}
