#!/usr/bin/env bash
# Create a visible cmux tab, then create the matching git worktree inside it
# and start an agent with the original prompt.

set -euo pipefail

readonly CMUX_BIN="${CMUX_BIN:-/Applications/cmux.app/Contents/Resources/bin/cmux}"
readonly BRANCH_NAME_MODEL="${GWAI_BRANCH_MODEL:-haiku}"

usage() {
  cat <<'USAGE'
Usage: gwai-cmux [--provider claude|codex] [--base-dir DIR] [--branch-name NAME] <prompt>

Opens a new cmux terminal tab first, then generates a branch name with a
lightweight Claude model, creates or reuses a worktree via gw-create-worktree,
and starts cl/cdx with <prompt> as the first message inside that tab.

If --base-dir is omitted, the top cmux workspace directory is used.
If --provider is omitted, codex is used.
--branch-name is intended for the handoff into the new cmux tab.
USAGE
}

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

require_command() {
  local name="$1"
  command -v "$name" >/dev/null 2>&1 || die "$name not found in PATH"
}

quote_zsh_arg() {
  printf '%q' "$1"
}

resolve_script_path() {
  local script_path="${BASH_SOURCE[0]}"
  local script_dir

  if [[ "$script_path" = /* ]]; then
    printf '%s\n' "$script_path"
    return 0
  fi

  if [[ "$script_path" == */* ]]; then
    script_dir=$(cd "$(dirname "$script_path")" && pwd -P) ||
      die "failed to resolve script directory: $script_path"
    printf '%s/%s\n' "$script_dir" "$(basename "$script_path")"
    return 0
  fi

  command -v "$script_path" || die "failed to resolve script path: $script_path"
}

resolve_cmux_top_base_dir() {
  local workspaces_json top_workspace_json base_dir

  workspaces_json=$("$CMUX_BIN" --json workspace list) ||
    die "failed to read cmux workspace list"

  top_workspace_json=$(printf '%s\n' "$workspaces_json" |
    jq -c '.workspaces | sort_by(.index) | .[0] // empty') ||
    die "failed to parse cmux workspace list"

  [[ -n "$top_workspace_json" && "$top_workspace_json" != "null" ]] ||
    die "cmux workspace list is empty"

  base_dir=$(printf '%s\n' "$top_workspace_json" | jq -r '.current_directory // empty') ||
    die "failed to parse top cmux workspace"

  [[ -n "$base_dir" ]] ||
    die "top cmux workspace did not report current_directory"

  printf '%s\n' "$base_dir"
}

validate_branch_name() {
  local branch_name="$1"

  [[ "$branch_name" =~ ^(feat|fix|refactor|docs|test|chore|perf)-[a-z0-9][a-z0-9-]*$ ]] ||
    die "branch name is invalid: $branch_name"
}

generate_branch_name() {
  local prompt="$1"
  local naming_prompt naming_output branch_type branch_slug branch_name field_count

  naming_prompt="Generate exactly one git branch type and slug for the task below.
Rules:
- Output exactly two tokens separated by one space: <type> <slug>
- <type> must be one of: feat, fix, refactor, docs, test, chore, perf
- <slug> must be kebab-case, ASCII only, 3-7 words.
- Do not include the type in <slug>. The shell function prefixes it.
- Output ONLY the two tokens. No quotes, no commentary, no trailing punctuation.

Task: ${prompt}"

  naming_output=$(claude -p --model "$BRANCH_NAME_MODEL" "$naming_prompt" 2>/dev/null |
    tr -d '\r`"' |
    sed -E "s/'//g; s/^[[:space:]]+|[[:space:]]+$//g" |
    awk 'NF { print; exit }') ||
    die "branch name generation failed"

  [[ -n "$naming_output" ]] ||
    die "branch name generation returned empty output"

  field_count=$(printf '%s\n' "$naming_output" | awk '{ print NF }')
  [[ "$field_count" == "2" ]] ||
    die "branch name generation returned invalid output: $naming_output"

  branch_type=${naming_output%% *}
  branch_slug=${naming_output#* }

  [[ "$branch_type" =~ ^(feat|fix|refactor|docs|test|chore|perf)$ ]] ||
    die "generated branch type is invalid: $branch_type"
  [[ "$branch_slug" =~ ^[a-z0-9][a-z0-9-]*$ ]] ||
    die "generated branch slug is invalid: $branch_slug"

  branch_name="${branch_type}-${branch_slug}"
  validate_branch_name "$branch_name"

  printf '%s\n' "$branch_name"
}

create_worktree() {
  local base_dir="$1"
  local branch_name="$2"
  local creation_output worktree_dir output_file helper_status

  output_file=$(mktemp) || die "failed to create temporary output file"
  : >"$output_file"

  set +e
  (cd "$base_dir" && gw-create-worktree "$branch_name") \
    > >(tee -a "$output_file" >&2) \
    2> >(tee -a "$output_file" >&2)
  helper_status=$?
  set -e

  creation_output=$(cat "$output_file") || {
    rm -f "$output_file"
    die "failed to read worktree creation output"
  }
  rm -f "$output_file"

  [[ "$helper_status" -eq 0 ]] ||
    die "failed to create worktree for branch: $branch_name"

  worktree_dir=$(printf '%s\n' "$creation_output" |
    awk -F= '$1 == "WORKTREE_PATH" { print substr($0, index($0, "=") + 1) }' |
    tail -1)

  [[ -n "$worktree_dir" ]] ||
    die "gw-create-worktree did not output WORKTREE_PATH"
  [[ -d "$worktree_dir" ]] ||
    die "worktree path does not exist: $worktree_dir"

  printf '%s\n' "$worktree_dir"
}

create_prompt_file() {
  local prompt="$1"
  local prompt_file

  prompt_file=$(mktemp "${TMPDIR:-/tmp}/gwai-cmux-prompt.XXXXXX") ||
    die "failed to create prompt file"
  chmod 600 "$prompt_file" || {
    rm -f "$prompt_file"
    die "failed to secure prompt file: $prompt_file"
  }
  printf '%s' "$prompt" >"$prompt_file" || {
    rm -f "$prompt_file"
    die "failed to write prompt file: $prompt_file"
  }

  printf '%s\n' "$prompt_file"
}

read_prompt_file() {
  local prompt_file="$1"
  local file_prompt

  [[ -f "$prompt_file" ]] ||
    die "prompt file does not exist: $prompt_file"
  [[ -r "$prompt_file" ]] ||
    die "prompt file is not readable: $prompt_file"

  file_prompt=$(cat "$prompt_file") ||
    die "failed to read prompt file: $prompt_file"
  rm -f "$prompt_file" ||
    die "failed to remove prompt file: $prompt_file"

  printf '%s' "$file_prompt"
}

parse_surface_ref() {
  jq -r '.surface_ref // .surface.ref // .ref // empty'
}

rename_cmux_tab() {
  local surface_ref="$1"
  local title="$2"

  "$CMUX_BIN" rename-tab --surface "$surface_ref" --title "$title" >/dev/null
}

rename_current_cmux_tab() {
  local title="$1"

  [[ -x "$CMUX_BIN" ]] || die "cmux not found at $CMUX_BIN"

  if [[ -n "${CMUX_SURFACE_ID:-}" ]]; then
    rename_cmux_tab "$CMUX_SURFACE_ID" "$title" ||
      die "failed to rename current cmux tab: $title"
  else
    "$CMUX_BIN" rename-tab --title "$title" >/dev/null ||
      die "failed to rename current cmux tab: $title"
  fi
}

send_command_to_surface() {
  local surface_ref="$1"
  local command="$2"
  local attempt

  for attempt in {1..20}; do
    if "$CMUX_BIN" send --surface "$surface_ref" "${command}\\r"; then
      return 0
    fi
    printf '[gwai-cmux] Waiting for cmux tab input (%d/20)...\n' "$attempt" >&2
    sleep 0.2
  done

  return 1
}

open_cmux_tab() {
  local provider="$1"
  local base_dir="$2"
  local prompt_file="$3"
  local branch_name="$4"
  local script_path command surface_json surface_ref tab_title

  script_path=$(resolve_script_path)
  command="$(quote_zsh_arg "$script_path") --inside-tab --provider $(quote_zsh_arg "$provider") --base-dir $(quote_zsh_arg "$base_dir") --prompt-file $(quote_zsh_arg "$prompt_file")"
  if [[ -n "$branch_name" ]]; then
    command+=" --branch-name $(quote_zsh_arg "$branch_name")"
    tab_title="$branch_name"
  else
    tab_title="gwai-cmux setup"
  fi

  surface_json=$("$CMUX_BIN" --json new-surface \
    --type terminal \
    --working-directory "$base_dir" \
    --focus true) || {
    rm -f "$prompt_file"
    die "failed to create cmux tab"
  }

  surface_ref=$(printf '%s\n' "$surface_json" | parse_surface_ref) || {
    rm -f "$prompt_file"
    die "failed to parse new cmux tab"
  }

  [[ -n "$surface_ref" ]] || {
    rm -f "$prompt_file"
    die "cmux did not report new surface_ref"
  }

  if ! rename_cmux_tab "$surface_ref" "$tab_title"; then
    rm -f "$prompt_file"
    die "failed to name cmux tab"
  fi
  if ! send_command_to_surface "$surface_ref" "$command"; then
    rm -f "$prompt_file"
    die "failed to start setup in cmux tab"
  fi

  printf '%s\n' "$surface_ref"
}

start_agent() {
  local provider="$1"
  local worktree_dir="$2"
  local prompt="$3"
  local launcher command

  case "$provider" in
    claude) launcher="cl" ;;
    codex) launcher="cdx" ;;
    *) die "provider must be claude or codex" ;;
  esac

  require_command zsh

  command="cd $(quote_zsh_arg "$worktree_dir") && ${launcher} $(quote_zsh_arg "$prompt")"
  exec zsh -lic "$command"
}

provider="${GWAI_CMUX_PROVIDER:-codex}"
base_dir=""
branch_name=""
prompt_file=""
inside_tab=0
prompt_parts=()

while (($# > 0)); do
  case "$1" in
    --inside-tab)
      inside_tab=1
      ;;
    --provider)
      shift
      (($# > 0)) || die "--provider requires claude or codex"
      provider="$1"
      ;;
    --provider=*)
      provider="${1#--provider=}"
      ;;
    --base-dir)
      shift
      (($# > 0)) || die "--base-dir requires a directory"
      base_dir="$1"
      ;;
    --base-dir=*)
      base_dir="${1#--base-dir=}"
      ;;
    --branch-name)
      shift
      (($# > 0)) || die "--branch-name requires a branch name"
      branch_name="$1"
      ;;
    --branch-name=*)
      branch_name="${1#--branch-name=}"
      ;;
    --prompt-file)
      shift
      (($# > 0)) || die "--prompt-file requires a file path"
      prompt_file="$1"
      ;;
    --prompt-file=*)
      prompt_file="${1#--prompt-file=}"
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    --)
      shift
      prompt_parts+=("$@")
      break
      ;;
    -*)
      die "unknown option: $1"
      ;;
    *)
      prompt_parts+=("$1")
      ;;
  esac
  shift
done

case "$provider" in
  claude | codex) ;;
  *) die "provider must be claude or codex" ;;
esac

if [[ -n "$prompt_file" && "${#prompt_parts[@]}" -gt 0 ]]; then
  die "--prompt-file cannot be combined with prompt arguments"
fi
if [[ -n "$prompt_file" && ! -t 0 ]]; then
  die "--prompt-file cannot be combined with stdin prompt"
fi

if [[ -n "$prompt_file" ]]; then
  prompt=$(read_prompt_file "$prompt_file")
else
  prompt="${prompt_parts[*]}"
fi

if [[ -z "$prompt_file" && ! -t 0 ]]; then
  stdin_prompt=$(cat)
  if [[ -n "$stdin_prompt" ]]; then
    if [[ -n "$prompt" ]]; then
      prompt="${prompt}
${stdin_prompt}"
    else
      prompt="$stdin_prompt"
    fi
  fi
fi

[[ -n "$prompt" ]] || die "prompt is empty"

if [[ -z "$base_dir" && "$inside_tab" -eq 0 ]]; then
  [[ -x "$CMUX_BIN" ]] || die "cmux not found at $CMUX_BIN"
  require_command jq
  base_dir=$(resolve_cmux_top_base_dir)
fi
if [[ -z "$base_dir" ]]; then
  base_dir=$(pwd)
fi

[[ -d "$base_dir" ]] || die "base directory does not exist: $base_dir"

if [[ "$inside_tab" -eq 0 ]]; then
  [[ -x "$CMUX_BIN" ]] || die "cmux not found at $CMUX_BIN"
  require_command jq
  [[ -z "$branch_name" ]] || validate_branch_name "$branch_name"

  prompt_file=$(create_prompt_file "$prompt")
  surface_ref=$(open_cmux_tab "$provider" "$base_dir" "$prompt_file" "$branch_name")
  printf 'Started setup in cmux tab %s from %s\n' "$surface_ref" "$base_dir"
  exit 0
fi

require_command git
require_command gw-create-worktree
if [[ -z "$branch_name" ]]; then
  require_command claude
fi

git -C "$base_dir" rev-parse --show-toplevel >/dev/null 2>&1 ||
  die "base directory is not in a git repository: $base_dir"

printf '[gwai-cmux] Provider: %s\n' "$provider"
printf '[gwai-cmux] Base: %s\n' "$base_dir"
if [[ -z "$branch_name" ]]; then
  printf '[gwai-cmux] Generating branch name with claude %s...\n' "$BRANCH_NAME_MODEL"
  branch_name=$(generate_branch_name "$prompt")
else
  validate_branch_name "$branch_name"
fi
rename_current_cmux_tab "$branch_name"
printf '[gwai-cmux] Branch: %s\n' "$branch_name"
printf '[gwai-cmux] Creating worktree...\n'

worktree_dir=$(create_worktree "$base_dir" "$branch_name")
printf '[gwai-cmux] Starting %s in %s\n' "$provider" "$worktree_dir"
start_agent "$provider" "$worktree_dir" "$prompt"
