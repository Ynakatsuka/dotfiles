#!/usr/bin/env bash
# Upgrade mise-managed tools while still allowing non-GitHub backends without a token.

set -euo pipefail

LOG_FILE=""

cleanup() {
  if [ -n "$LOG_FILE" ]; then
    rm -f "$LOG_FILE"
  fi
}

find_github_token_from_gh() {
  local candidate output

  for candidate in \
    "$HOME"/.local/share/mise/installs/gh/latest/*/bin/gh \
    "$HOME"/.local/share/mise/installs/gh/*/*/bin/gh \
    "$HOME"/.local/share/mise/installs/gh/*/bin/gh \
    /usr/bin/gh \
    /usr/local/bin/gh \
    /opt/homebrew/bin/gh \
    "$HOME/.local/bin/gh"; do
    if [ -x "$candidate" ]; then
      if output="$("$candidate" auth token 2>/dev/null)" && is_github_token "$output"; then
        printf '%s\n' "$output"
        return 0
      fi
    fi
  done

  candidate="$(command -v gh 2>/dev/null || true)"
  case "$candidate" in
    "" | *"/mise/shims/gh") return 1 ;;
    *)
      if output="$("$candidate" auth token 2>/dev/null)" && is_github_token "$output"; then
        printf '%s\n' "$output"
        return 0
      fi
      ;;
  esac

  return 1
}

is_github_token() {
  local token="$1"

  [ -n "$token" ] && [[ "$token" != *[!A-Za-z0-9_-]* ]]
}

resolve_github_token() {
  if [ -n "${GITHUB_TOKEN:-}" ]; then
    if ! is_github_token "$GITHUB_TOKEN"; then
      echo "[ERROR] GITHUB_TOKEN contains characters that cannot be used in an HTTP Authorization header" >&2
      return 2
    fi
    printf '%s\n' "$GITHUB_TOKEN"
    return 0
  fi

  find_github_token_from_gh
}

main() {
  local self_update_available status token

  # Package-manager builds expose self-update help but reject the update itself.
  self_update_available="$(
    mise doctor --json |
      jq -r 'if has("self_update_available") and (.self_update_available | type == "boolean") then .self_update_available else error("self_update_available must be a boolean") end'
  )"

  case "$self_update_available" in
    true)
      mise self-update -y
      ;;
    false)
      echo "[INFO] mise is managed by the system package manager; skipping self-update"
      ;;
    *)
      echo "[ERROR] mise doctor returned an unexpected self_update_available value: $self_update_available" >&2
      return 1
      ;;
  esac

  token=""
  if token="$(resolve_github_token)"; then
    :
  elif [ "$?" -eq 2 ]; then
    return 2
  fi

  LOG_FILE="$(mktemp)"
  trap cleanup EXIT

  if [ -n "$token" ]; then
    if GITHUB_TOKEN="$token" mise up "$@" >"$LOG_FILE" 2>&1; then
      status=0
    else
      status="$?"
    fi
  elif mise up "$@" >"$LOG_FILE" 2>&1; then
    status=0
  else
    status="$?"
  fi

  if [ "$status" -eq 0 ]; then
    mise reshim --force
    if [ -s "$LOG_FILE" ]; then
      cat "$LOG_FILE"
    fi
    "$HOME/.local/bin/dotfiles-agent-env-check"
    return 0
  fi

  sed 's/^/[WARN] mise up: /' "$LOG_FILE" >&2
  return "$status"
}

main "$@"
