# Ensure that a non-login, non-interactive shell has a defined environment.
if [[ ( "$SHLVL" -eq 1 && ! -o LOGIN ) && -s "${ZDOTDIR:-$HOME}/.zprofile" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprofile"
fi

# Enable mise-managed tools in non-interactive shells (SSH exec, agents, scripts).
# Shim resolution only, no precmd hook or tool initialization overhead.
if [[ -d "$HOME/.local/share/mise/shims" ]]; then
  export PATH="$HOME/.local/share/mise/shims:$PATH"
fi

# Gemini CLI: skip keytar/Secret Service to prevent indefinite hangs on
# headless SSH-only servers where the GNOME Keyring is locked. With this set,
# tokens live in a file under ~/.gemini/ (oauth_creds.json or
# gemini-credentials.json depending on the active backend) instead of the OS
# keychain.
export GEMINI_FORCE_FILE_STORAGE=true
