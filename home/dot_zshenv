#
# Defines environment variables.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

# Ensure that a non-login, non-interactive shell has a defined environment.
if [[ ( "$SHLVL" -eq 1 && ! -o LOGIN ) && -s "${ZDOTDIR:-$HOME}/.zprofile" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprofile"
fi

# Locale — set early so all shells (interactive and non-interactive) share the same locale.
export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
export LANGUAGE=en_US.UTF-8

# cmux writes per-surface CLI shims before .zshrc loads. Keep that generated
# write compatible with Prezto's later noclobber setting.
if [[ -n "${CMUX_SHELL_INTEGRATION_DIR:-}" && -n "${CMUX_SURFACE_ID:-}" ]]; then
  setopt CLOBBER
fi

# Static, hardware-independent PATH additions.
# $HOME/.local/bin: user-installed binaries (pip --user, manual scripts, etc.)
# Go bin: tools installed via `go install`; GOPATH is also consumed by tools.zsh.
export GOPATH="$HOME/go"
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
  export PATH="$HOME/.local/bin:$PATH"
fi
if [[ ":$PATH:" != *":$GOPATH/bin:"* ]]; then
  export PATH="$PATH:$GOPATH/bin"
fi

# Enable mise-managed tools in non-interactive shells (SSH exec, agents, scripts).
# Shim resolution only, no precmd hook or tool initialization overhead.
if [[ -d "$HOME/.local/share/mise/shims" ]]; then
  export PATH="$HOME/.local/share/mise/shims:$PATH"
fi

# Gemini CLI: skip keytar/Secret Service to prevent indefinite hangs on
# headless SSH-only servers where the GNOME Keyring is locked. With this set,
# tokens live in a file under ~/.gemini/ (oauth_creds.json or
# gemini-credentials.json depending on the active backend) instead of the OS
# keychain.
export GEMINI_FORCE_FILE_STORAGE=true
