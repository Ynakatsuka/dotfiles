#!/bin/bash
# Decrypt age private key on first run.
# Prompts for passphrase once; subsequent chezmoi operations use the cached key.

KEY_PATH="${HOME}/.config/chezmoi/key.txt"
ENCRYPTED_KEY="{{ joinPath .chezmoi.sourceDir ".age-key.age" }}"

resolve_age_cmd() {
    for candidate in /usr/bin/age /usr/local/bin/age /opt/homebrew/bin/age "$HOME/.local/bin/age"; do
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    # mise installs age under either <version>/bin/age or <version>/age/age
    # depending on the backend, so both layouts are checked.
    for candidate in "$HOME"/.local/share/mise/installs/age/*/bin/age \
        "$HOME"/.local/share/mise/installs/age/*/age/age; do
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    candidate="$(command -v age 2>/dev/null || true)"
    case "$candidate" in
        "" | *"/mise/shims/age") return 1 ;;
        *)
            printf '%s\n' "$candidate"
            return 0
            ;;
    esac
}

if [ -f "$KEY_PATH" ]; then
    exit 0
fi

if [ ! -f "$ENCRYPTED_KEY" ]; then
    echo "[WARN] Encrypted age key not found: $ENCRYPTED_KEY"
    echo "[WARN] Encrypted files will not be decrypted."
    exit 0
fi

if ! AGE_CMD="$(resolve_age_cmd)"; then
    echo "[WARN] age not found. Install age first, then run 'chezmoi apply'."
    exit 0
fi

echo "[INFO] Decrypting age key (passphrase required once)..."
mkdir -p "$(dirname "$KEY_PATH")"
"$AGE_CMD" -d -o "$KEY_PATH" "$ENCRYPTED_KEY"
chmod 600 "$KEY_PATH"
echo "[INFO] Age key cached at $KEY_PATH"
