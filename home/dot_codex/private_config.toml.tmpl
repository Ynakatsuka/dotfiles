hide_agent_reasoning = true
network_access = true
approval_policy = "never"
sandbox_mode = "danger-full-access"
model = "gpt-5.5"
model_reasoning_effort = "xhigh"
service_tier = "default"
suppress_unstable_features_warning = true

[features]
hooks = true
multi_agent = true
external_migration = false
goals = true
default_mode_request_user_input = true

[tools]
unified_exec = true
streamable_shell = true

[agents]
max_threads = 6
max_depth = 1

[tui]
status_line = [
  "model-with-reasoning",
  "fast-mode",
  "git-branch",
  "branch-changes",
  "context-remaining",
  "five-hour-limit",
  "weekly-limit",
  "used-tokens",
  "current-dir",
]

# Suppress model-availability NUX banners by pinning shown_count to the
# MAX_SHOW_COUNT (4) defined in codex-rs/tui/src/app/startup_prompts.rs.
[tui.model_availability_nux]
"gpt-5.5" = 4

{{- if lookPath "ghq" }}
{{- range $repo := (splitList "\n" (trim (output "ghq" "list" "-p"))) }}
{{- if $repo }}
[projects.{{ $repo | quote }}]
trust_level = "trusted"

{{- end }}
{{- end }}
{{- end }}
{{/* Preserve Codex's runtime hook trust state across chezmoi applies. */ -}}
{{- $codexConfig := joinPath .chezmoi.homeDir ".codex/config.toml" }}
{{- if stat $codexConfig }}
{{- $hookState := trim (output "awk" "BEGIN { in_hooks = 0 } /^\\[hooks\\.state\\]$/ { in_hooks = 1; print; next } in_hooks && /^\\[/ && $0 !~ /^\\[hooks\\.state(\\]|\\.)/ { in_hooks = 0 } in_hooks { print }" $codexConfig) }}
{{- if $hookState }}

{{ $hookState -}}
{{- end }}
{{- end }}

[projects.{{ .chezmoi.homeDir | quote }}]
trust_level = "trusted"
