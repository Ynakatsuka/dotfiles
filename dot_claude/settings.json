{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "deny": [
      "NotebookEdit"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/check-mojibake.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = \"Darwin\" ]; then SESSION=\"${CLAUDE_SESSION_NAME:-不明}\"; osascript -e \"display notification \\\"セッション: $SESSION - Agentから質問があります.\\\" with title \\\"Claude Code\\\"\"; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ \"$(uname)\" = \"Darwin\" ]; then SESSION=\"${CLAUDE_SESSION_NAME:-不明}\"; osascript -e \"display notification \\\"セッション: $SESSION - 作業が完了しました.\\\" with title \\\"Claude Code\\\"\"; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccusage statusline"
  },
  "skipDangerousModePermissionPrompt": true,
  "plansDirectory": "./.plans",
  "autoUpdatesChannel": "latest",
  "model": "opus[1m]"
}