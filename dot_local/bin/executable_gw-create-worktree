#!/usr/bin/env bash
# Shared git worktree creation helper for interactive shell helpers and skills.

set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: gw-create-worktree <branch_name>

Creates or reuses a git worktree using the repository convention:
  ${repo_root}-worktree/${branch_name//\//-}

Outputs machine-readable lines:
  WORKTREE_PATH=<path>
  WORKTREE_CREATED=<0|1>
USAGE
}

branch_name="${1:-}"
if [[ -z "$branch_name" || "${branch_name}" == "-h" || "${branch_name}" == "--help" ]]; then
  usage >&2
  if [[ -z "$branch_name" ]]; then
    exit 2
  fi
  exit 0
fi

if [[ $# -ne 1 ]]; then
  usage >&2
  exit 2
fi

trust_codex_project() {
  local project_path="$1"
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  local config_file="$codex_home/config.toml"
  local escaped_project_path

  mkdir -p "$codex_home"
  touch "$config_file"

  escaped_project_path="${project_path//\\/\\\\}"
  escaped_project_path="${escaped_project_path//\"/\\\"}"

  if grep -F -x -q -- "[projects.\"$escaped_project_path\"]" "$config_file"; then
    return 0
  fi

  {
    printf '\n[projects."%s"]\n' "$escaped_project_path"
    printf 'trust_level = "trusted"\n'
  } >>"$config_file"
}

git_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Error: not in a git repository" >&2
  exit 1
}

original_root="$(git worktree list --porcelain | head -1 | sed 's/^worktree //')"
if [[ "$git_root" != "$original_root" ]]; then
  echo "Currently in a worktree. Switching to main repository: $original_root"
  cd "$original_root"
  git_root="$original_root"
fi

worktree_base="${git_root}-worktree"
sanitized="${branch_name//\//-}"
worktree_dir="${worktree_base}/${sanitized}"

existing_wt="$(
  git worktree list --porcelain |
    awk -v b="$branch_name" '
      /^worktree/ { wt = $2 }
      $1 == "branch" && $2 == "refs/heads/" b { print wt; exit }
    '
)"
if [[ -n "$existing_wt" ]]; then
  echo "Worktree for '$branch_name' already exists at: $existing_wt"
  echo "WORKTREE_PATH=$existing_wt"
  echo "WORKTREE_CREATED=0"
  exit 0
fi

if [[ -e "$worktree_dir" ]]; then
  echo "Error: '$worktree_dir' already exists but is not a registered worktree." >&2
  echo "Inspect and remove manually before retrying." >&2
  exit 1
fi

echo "Fetching from origin..."
git fetch origin --prune

base_candidates=(staging main master)
chosen_base=""
chosen_base_ref=""

for base in "${base_candidates[@]}"; do
  if ! git show-ref --verify --quiet "refs/remotes/origin/$base"; then
    continue
  fi

  if [[ -z "$chosen_base" ]]; then
    chosen_base="$base"
    chosen_base_ref="origin/$base"
  fi

  checked_out_at="$(
    git worktree list --porcelain |
      awk -v b="$base" '
        /^worktree/ { wt = $2 }
        $1 == "branch" && $2 == "refs/heads/" b { print wt; exit }
      '
  )"

  if [[ -n "$checked_out_at" ]]; then
    status_output="$(git -C "$checked_out_at" status --porcelain)" || {
      echo "Error: failed to inspect '$base' worktree at $checked_out_at." >&2
      exit 1
    }

    if [[ -n "$status_output" ]]; then
      echo "Warning: '$base' has uncommitted changes in $checked_out_at; leaving it unchanged." >&2
      echo "Warning: new worktrees will still be based on fetched origin/$base." >&2
      continue
    fi

    echo "Fast-forwarding '$base' (checked out at $checked_out_at)..."
    if ! git -C "$checked_out_at" merge --ff-only "origin/$base"; then
      echo "Error: failed to fast-forward '$base' in $checked_out_at." >&2
      echo "Resolve branch divergence there, then retry." >&2
      exit 1
    fi
  elif git show-ref --verify --quiet "refs/heads/$base"; then
    echo "Fast-forwarding local '$base' to origin/$base..."
    if ! git fetch origin "$base:$base"; then
      echo "Error: local '$base' has diverged from origin/$base." >&2
      echo "Reconcile manually (rebase / reset), then retry." >&2
      exit 1
    fi
  else
    echo "Creating local '$base' from origin/$base..."
    git branch "$base" "origin/$base"
  fi
done

if [[ -z "$chosen_base" ]]; then
  echo "Error: none of staging/main/master exist on origin. Cannot pick base branch." >&2
  exit 1
fi

echo "Base branch resolved: $chosen_base_ref"

if git show-ref --verify --quiet "refs/remotes/origin/$branch_name"; then
  if git show-ref --verify --quiet "refs/heads/$branch_name"; then
    echo "Reusing local branch '$branch_name' for the worktree."
    git worktree add "$worktree_dir" "$branch_name"
  else
    echo "Checking out remote branch '$branch_name' into worktree..."
    git worktree add "$worktree_dir" "$branch_name"
  fi
elif git show-ref --verify --quiet "refs/heads/$branch_name"; then
  echo "Reusing local-only branch '$branch_name' for the worktree."
  git worktree add "$worktree_dir" "$branch_name"
else
  echo "Creating new branch '$branch_name' from '$chosen_base_ref'..."
  git worktree add -b "$branch_name" --no-track "$worktree_dir" "$chosen_base_ref"
fi

for file in .env .envrc; do
  if [[ -f "$git_root/$file" && ! -f "$worktree_dir/$file" ]]; then
    echo "Copying $file to worktree..."
    cp "$git_root/$file" "$worktree_dir/$file"
  fi
done

if [[ -f "$worktree_dir/.envrc" ]] && command -v direnv >/dev/null 2>&1; then
  (cd "$worktree_dir" && direnv allow)
fi

if command -v mise >/dev/null 2>&1; then
  echo "Trusting mise config files..."
  (cd "$worktree_dir" && mise trust --all --yes)
fi

echo "Trusting Codex project..."
trust_codex_project "$worktree_dir"

echo ""
echo "Worktree ready: $worktree_dir"
echo "WORKTREE_PATH=$worktree_dir"
echo "WORKTREE_CREATED=1"
